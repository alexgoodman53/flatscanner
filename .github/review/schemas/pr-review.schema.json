{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "verdict", "findings"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "verdict": {
      "type": "string",
      "enum": ["approve", "comment", "request_changes"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "file", "line", "title", "body"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "body": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4000
          }
        }
      }
    }
  }
}
